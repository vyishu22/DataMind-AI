# ─── AI ───────────────────────────────────────────────────────────────────────
# Working free models on OpenRouter (July 2026):
#   google/gemma-4-26b-a4b-it:free  (primary)
#   openai/gpt-oss-20b:free         (fallback)
#   nvidia/nemotron-nano-9b-v2:free (fallback)
# The client auto-falls back through all three, so set the best one here.
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
AI_PROVIDER=openrouter

# ─── File Upload ───────────────────────────────────────────────────────────────
